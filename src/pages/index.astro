---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import SecurityTrustStrip from '~/components/widgets/SecurityTrustStrip.astro';
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ItemGrid from '~/components/ui/ItemGrid.astro';
import ItemGrid2 from '~/components/ui/ItemGrid2.astro';
import Button from '~/components/ui/Button.astro';
import NetworkStats from '~/components/dynamic/NetworkStats.svelte';
import EcosystemDiagram from '~/components/dynamic/EcosystemDiagram.svelte';
import { externalLinks } from '~/navigation';
import Partners from '~/components/Partners.astro';

const metadata = {
  title: 'VerifiedX — The Financial Operating System for Bitcoin.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Section 3: Hero -->
  <section class="spy-section">
    <Hero />
  </section>

  <!-- Section 4: Security Trust Strip -->
  <SecurityTrustStrip />

  <!-- Section 5: Ecosystem Partners / Integrations -->
  <section class="spy-section pt-16" id="section-ecosystem">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <Partners />
    </WidgetWrapper>
  </section>

  <!-- Section 6: Network Stats -->
  <section class="spy-section pt-8" id="section-stats">
    <NetworkStats client:load />
  </section>

  <!-- Section 7: Ecosystem Diagram (Architecture Stack + Flywheel) -->
  <section class="spy-section pt-16" id="section-how-it-works">
    <EcosystemDiagram client:visible />
  </section>

  <!-- Section 8: Use Bitcoin as Financial Capital -->
  <section class="spy-section pt-16" id="section-capital">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <h2 class="font-bold font-heading text-heading text-5xl text-center tracking-tight mb-10">
        Use Bitcoin as Financial Capital
      </h2>

      <ItemGrid
        items={[
          {
            title: 'Send Global Payments',
            description: 'Send digital assets instantly anywhere in the world using Butterfly.',
            icon: 'tabler:send',
            callToAction: { text: 'Open Butterfly', href: '#' },
          },
          {
            title: 'Earn Yield on Bitcoin',
            description: 'Use vBTC to participate in decentralized financial markets.',
            icon: 'tabler:chart-line',
            callToAction: { text: 'Learn About vBTC', href: '#' },
          },
          {
            title: 'Own Your Money',
            description: 'Self-custodial wallets ensure users control their assets.',
            icon: 'tabler:shield-lock',
            callToAction: { text: 'Download Wallet', href: externalLinks.webWallet },
          },
          {
            title: 'Build Financial Applications',
            description: 'Developers can build financial tools, marketplaces, and decentralized apps.',
            icon: 'tabler:code',
            callToAction: { text: 'Developer Docs', href: externalLinks.docs },
          },
        ]}
        columns={4}
        classes={{
          container: 'gap-6',
          title: 'md:text-[1.1rem]',
          icon: 'text-white bg-primary rounded-full w-10 h-10 p-2 md:w-12 md:h-12 md:p-3 mr-4 rtl:ml-4 rtl:mr-0',
        }}
      />
    </WidgetWrapper>
  </section>

  <!-- Section 10: vBTC -->
  <section class="spy-section pt-16" id="section-vbtc">
    <WidgetWrapper containerClass={`max-w-7xl mx-auto`}>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <h2 class="text-4xl md:text-5xl font-bold font-heading text-heading tracking-tight mb-6">
            Unlock the Financial Utility of <span class="text-btc">Bitcoin</span>
          </h2>
          <p class="text-xl text-muted mb-8">
            vBTC enables Bitcoin holders to participate in financial markets while maintaining full collateralization
            and self custody. Each vBTC is backed 1:1 by Bitcoin.
          </p>

          <div class="mb-4">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold">Retail</p>
            <div class="flex flex-wrap gap-2">
              <Button variant="primary" href="#">Mint vBTC</Button>
              <Button variant="secondary" href={externalLinks.vbtcDocs} target="_blank">How vBTC Works</Button>
            </div>
          </div>

          <div>
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold">Institutional</p>
            <div class="flex flex-wrap gap-2">
              <Button variant="secondary" href="#">Institutional Overview</Button>
              <Button variant="secondary" href="#">Custody Integration</Button>
            </div>
          </div>
        </div>

        <!-- Right: Security Flow Diagram -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div
            class="rounded-lg border border-gray-700 bg-[#0a0a0a] p-6 md:p-8 font-mono text-sm md:text-base shadow-2xl"
          >
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-800">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span class="ml-2 text-gray-500 text-xs">vbtc://flow</span>
            </div>
            <pre
              class="text-green-400 leading-relaxed whitespace-pre"><span class="text-btc font-bold">BTC Deposit</span>
   &darr;
<span class="text-gray-300">FROST MPC Validators</span>
   &darr;
<span class="text-btc font-bold">vBTC Mint</span>
   &darr;
<span class="text-gray-300">DeFi</span> / <span class="text-gray-300">Payments</span> / <span class="text-gray-300">Agentic Markets</span></pre>
          </div>
        </div>
      </div>
    </WidgetWrapper>
  </section>

  <!-- Section 11: Self-Custodial Financial Applications -->
  <section class="spy-section pt-16" id="section-applications">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <h2 class="font-bold font-heading text-heading text-5xl text-center tracking-tight mb-10">
        Self-Custodial Financial Applications
      </h2>

      <ItemGrid2
        columns={3}
        items={[
          {
            title: 'Butterfly',
            description: 'Global payments and earning powered by the VerifiedX network.',
            callToAction: {
              variant: 'primary',
              text: 'Open Butterfly',
              href: '#',
            },
          },
          {
            title: 'Switchblade Wallet',
            description: 'Native wallet for interacting with VerifiedX and vBTC.',
            callToAction: {
              variant: 'primary',
              text: 'Download Wallet',
              href: externalLinks.webWallet,
              target: '_blank',
            },
          },
          {
            title: 'PulseXAI (Agentic Marketplaces)',
            description: 'AI agents interacting with financial markets and data.',
            callToAction: {
              variant: 'primary',
              text: 'Open PulseXAI',
              href: '#',
            },
          },
        ]}
        classes={{
          container: 'gap-4 md:gap-6',
          panel:
            'rounded-lg shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur border border-[#ffffff29] bg-[rgba(15,23,42,0.75)] p-6',
          icon: 'w-12 h-12 mb-6 text-primary',
        }}
      />
    </WidgetWrapper>
  </section>

  <!-- Section 12: Security & Institutional Infrastructure -->
  <section class="spy-section pt-16" id="section-security">
    <WidgetWrapper containerClass={`max-w-7xl mx-auto`}>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <h2 class="text-4xl md:text-5xl font-bold font-heading text-heading tracking-tight mb-6">
            Institutional-Grade Infrastructure
          </h2>

          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <Icon name="tabler:shield-check" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
              <span class="text-muted">Halborn security audits</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="tabler:search" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
              <span class="text-muted">Merkle Science compliance & block tracing tools</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="tabler:users-group" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
              <span class="text-muted">Validator consensus</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="tabler:key" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
              <span class="text-muted">Self-custodial architecture</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="tabler:code" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
              <span class="text-muted">Open source protocol with a unified framework</span>
            </li>
          </ul>

          <div class="flex flex-wrap gap-2">
            <Button variant="primary" href="#">Security Overview</Button>
            <Button variant="secondary" href="#">Audit Reports</Button>
            <Button variant="secondary" href={externalLinks.validatingDocs} target="_blank">Run Validator</Button>
            <Button variant="secondary" href="#">Institutional Solutions</Button>
          </div>
        </div>

        <!-- Right: Network Security Diagram -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div
            class="rounded-lg border border-gray-700 bg-[#0a0a0a] p-6 md:p-8 font-mono text-sm md:text-base shadow-2xl"
          >
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-800">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span class="ml-2 text-gray-500 text-xs">security://network</span>
            </div>
            <pre
              class="text-green-400 leading-relaxed whitespace-pre"><span class="text-primary font-bold">Validators</span>
   &darr;
<span class="text-gray-300">Consensus</span>
   &darr;
<span class="text-primary font-bold">Asset Security</span></pre>
          </div>
        </div>
      </div>
    </WidgetWrapper>
  </section>

  <!-- Section 14: Closing CTA -->
  <section class="spy-section pt-16 pb-20" id="section-cta">
    <WidgetWrapper containerClass={`max-w-4xl mx-auto text-center`}>
      <h2 class="font-bold font-heading text-heading text-5xl tracking-tight mb-6">
        The Future of Self-Custodial Finance
      </h2>
      <p class="text-xl text-muted max-w-3xl mx-auto mb-10">
        VerifiedX is building the infrastructure that enables Bitcoin to power a global self-custodial financial
        ecosystem.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button variant="primary" href="#">Open Butterfly</Button>
        <Button variant="secondary" href={externalLinks.docs} target="_blank">Start Building</Button>
        <Button variant="secondary" href="#">Institutional Infrastructure</Button>
      </div>
    </WidgetWrapper>
  </section>
</Layout>
