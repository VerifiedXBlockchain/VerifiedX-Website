---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import SecurityTrustStrip from '~/components/widgets/SecurityTrustStrip.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ItemGrid from '~/components/ui/ItemGrid.astro';
import Button from '~/components/ui/Button.astro';
import NetworkStats from '~/components/dynamic/NetworkStats.svelte';
import { externalLinks } from '~/navigation';
import Partners from '~/components/Partners.astro';

const metadata = {
  title: 'VerifiedX — The Financial Operating System for Bitcoin.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Section 3: Hero -->
  <section class="spy-section">
    <Hero />
  </section>

  <!-- Section 4: Security Trust Strip -->
  <SecurityTrustStrip />

  <!-- Section 5: Ecosystem Partners / Integrations -->
  <section class="spy-section pt-16" id="section-ecosystem">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <Partners />
    </WidgetWrapper>
  </section>

  <!-- Section 6: Network Stats -->
  <section class="spy-section pt-8" id="section-stats">
    <NetworkStats client:load />
  </section>

  <!-- Section 7: How VerifiedX Works -->
  <section class="spy-section pt-16" id="section-how-it-works">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <h2 class="font-bold font-heading text-heading text-5xl text-center tracking-tight">How VerifiedX Works</h2>
      <p class="mt-4 text-center text-xl text-muted max-w-3xl mx-auto">
        Bitcoin becomes programmable financial capital through the VerifiedX network.
      </p>

      <div class="py-10 flex justify-center">
        <div
          class="rounded-lg border border-gray-700 bg-[#0a0a0a] p-8 md:p-10 font-mono text-base md:text-lg text-center shadow-2xl max-w-md w-full"
        >
          <pre
            class="text-green-400 leading-loose whitespace-pre"><span class="text-primary font-bold">Bitcoin</span>
   &darr;
<span class="text-gray-300">VerifiedX Infrastructure</span>
   &darr;
<span class="text-gray-300">vBTC</span> &bull; <span class="text-gray-300">Stablecoins</span> &bull; <span class="text-gray-300">Smart Contracts</span>
   &darr;
<span class="text-gray-300">Payments</span> &bull; <span class="text-gray-300">Markets</span> &bull; <span class="text-gray-300">Applications</span>
   &darr;
<span class="text-primary font-bold">Users + AI Agents</span></pre>
        </div>
      </div>

      <div class="flex flex-row justify-center items-center gap-4">
        <Button variant="primary" href={externalLinks.docs} target="_blank">Network Architecture</Button>
        <div class="w-16 h-0.5 bg-primary opacity-40"></div>
        <Button variant="secondary" href={externalLinks.docs} target="_blank">Technical Documentation</Button>
      </div>
    </WidgetWrapper>
  </section>

  <!-- Section 8: Use Bitcoin as Financial Capital -->
  <section class="spy-section pt-16" id="section-capital">
    <WidgetWrapper containerClass={`max-w-6xl mx-auto`}>
      <h2 class="font-bold font-heading text-heading text-5xl text-center tracking-tight mb-10">
        Use Bitcoin as Financial Capital
      </h2>

      <ItemGrid
        items={[
          {
            title: 'Send Global Payments',
            description: 'Send digital assets instantly anywhere in the world using Butterfly.',
            icon: 'tabler:send',
            callToAction: { text: 'Open Butterfly', href: '#' },
          },
          {
            title: 'Earn Yield on Bitcoin',
            description: 'Use vBTC to participate in decentralized financial markets.',
            icon: 'tabler:chart-line',
            callToAction: { text: 'Learn About vBTC', href: '#' },
          },
          {
            title: 'Own Your Money',
            description: 'Self-custodial wallets ensure users control their assets.',
            icon: 'tabler:shield-lock',
            callToAction: { text: 'Download Wallet', href: externalLinks.webWallet },
          },
          {
            title: 'Build Financial Applications',
            description: 'Developers can build financial tools, marketplaces, and decentralized apps.',
            icon: 'tabler:code',
            callToAction: { text: 'Developer Docs', href: externalLinks.docs },
          },
        ]}
        columns={4}
        classes={{
          container: 'gap-6',
          title: 'md:text-[1.1rem]',
          icon: 'text-white bg-primary rounded-full w-10 h-10 p-2 md:w-12 md:h-12 md:p-3 mr-4 rtl:ml-4 rtl:mr-0',
        }}
      />
    </WidgetWrapper>
  </section>
</Layout>
