---
import Button from '~/components/ui/Button.astro';
import { externalLinks } from '~/navigation';
---

<section class="relative bg-black not-prose" id="hero">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <!-- Left Side: Copy + Button Groups -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <h1 class="text-4xl md:text-5xl font-bold font-heading dark:text-gray-200 leading-tight tracking-tight mb-6">
            The Financial Operating System for <span class="text-primary">Bitcoin</span>
          </h1>

          <p class="text-xl text-muted mb-4">
            VerifiedX is the financial operating system that turns Bitcoin into programmable financial capital.
          </p>

          <p class="text-base text-gray-400 mb-10">
            Payments, decentralized finance, tokenized assets, recovery vaulting, and the emerging agentic economy
            powered by a self-custodial network.
          </p>

          <!-- Button Group: Individuals -->
          <div class="mb-6">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold">Individuals</p>
            <div class="flex flex-wrap gap-2">
              <Button variant="blue" href="#" target="_blank">Open Butterfly</Button>
              <Button variant="secondary" href="#" target="_blank">Open PulseXAI</Button>
              <Button variant="secondary" href={externalLinks.webWallet} target="_blank">Download Wallet</Button>
            </div>
          </div>

          <!-- Button Group: Institutions -->
          <div class="mb-6">
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold">Institutions</p>
            <div class="flex flex-wrap gap-2">
              <Button variant="secondary" href="#">Institutional Infrastructure</Button>
              <Button variant="secondary" href="#">Integrate vBTC</Button>
            </div>
          </div>

          <!-- Button Group: Developers -->
          <div>
            <p class="text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold">Developers</p>
            <div class="flex flex-wrap gap-2">
              <Button variant="secondary" href={externalLinks.docs} target="_blank">Start Building</Button>
              <Button variant="secondary" href={externalLinks.docs} target="_blank">Documentation</Button>
            </div>
          </div>
        </div>

        <!-- Right Side: CLI Terminal Visual -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div
            class="rounded-lg border border-gray-700 bg-[#0a0a0a] p-6 md:p-8 font-mono text-sm md:text-base shadow-2xl"
          >
            <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-800">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span class="ml-2 text-gray-500 text-xs">verifiedx://network</span>
            </div>
            <pre
              class="text-green-400 leading-relaxed whitespace-pre"><span class="text-primary font-bold">Bitcoin</span>
   &darr;
<span class="text-vfx-blue font-bold">VerifiedX</span>
   &darr;
<span class="text-gray-300">Payments</span> &bull; <span class="text-gray-300">DeFi</span> &bull; <span class="text-gray-300">Wallets</span> &bull; <span class="text-gray-300">AI Agents</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
