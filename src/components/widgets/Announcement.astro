<div
  class="dark text-muted text-sm bg-black dark:bg-transparent dark:border-b dark:border-slate-800 dark:text-slate-400 hidden md:flex gap-1 overflow-hidden px-3 py-2 relative text-ellipsis whitespace-nowrap"
>
  <span
    class="dark:bg-slate-700 bg-white/40 dark:text-slate-300 font-semibold px-1 py-0.5 text-xs mr-0.5 rtl:mr-0 rtl:ml-0.5 inline-block"
    >NEW</span
  >
  <a
    href="#section-download"
    class="text-muted hover:underline dark:text-slate-400 font-medium relative inline-block"
    style="top: 1px;">SwitchBlade Wallet v5.3.0 now available &raquo;</a
  >
  <div class="ml-auto flex items-center" id="block-height-wrap" style="display:none;">
    <span class="text-xs font-medium text-slate-400">
      Current Block Height: <span id="block-height" class="text-[#73C4FA] font-semibold"></span>
    </span>
  </div>
</div>

<script>
  async function fetchBlockHeight() {
    try {
      const res = await fetch('https://data.verifiedx.io/api/metrics/');
      const data = await res.json();
      const el = document.getElementById('block-height');
      const wrap = document.getElementById('block-height-wrap');
      if (el && wrap && data.latest_block != null) {
        el.textContent = Number(data.latest_block).toLocaleString();
        wrap.style.display = '';
      }
    } catch {
      // silently fail — don't show anything
    }
  }
  fetchBlockHeight();
  setInterval(fetchBlockHeight, 10000);
</script>
