---
import Image from '~/components/common/Image.astro';

import { SITE } from 'astrowind:config';
const cubeImage = '~/assets/images/cube.gif';
---

<div
  class="self-center relative ml-2 rtl:ml-0 rtl:mr-2 text-2xl font-semibold text-gray-900 whitespace-nowrap dark:text-white logo"
  style="letter-spacing: 0.5px; top: 4px; margin-left: -8px;"
>
  <span class="flex items-center" style="font-size: 1.5em;">
    <Image src={cubeImage} alt="VerfiedX" width={60} height={60} class="logo-cube mr-1 relative" style="top: -3px;" />
    Verified<span class="text-vfx-blue font-semibold" style="font-size: 1.12em; position: relative; top: -1px;">X</span>
  </span>
</div>
